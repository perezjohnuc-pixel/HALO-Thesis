rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    function myUser() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    // ✅ Spark-friendly admin:
    // Either user doc role == admin OR email allowlist (works without Functions/custom claims)
    function isAdmin() {
      return signedIn() && (
        // allowlist admin emails for Spark demo
        (request.auth.token.email in [
          "perezjohn.uc@gmail.com"
        ])
        ||
        // role-based admin (if you set role=admin in users collection)
        (myUser() != null && myUser().role == "admin")
      );
    }

    // ----- Users -----
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();

      // Allow user profile creation by the user themselves.
      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == "user"
        && request.resource.data.createdAt is timestamp;

      // User can update safe fields only (no role / createdAt / uid changes)
      allow update: if isAdmin()
        || (isSelf(uid)
            && !request.resource.data.diff(resource.data).changedKeys()
                 .hasAny(["role", "createdAt", "uid"]));

      allow delete: if isAdmin();
    }

    // ----- Lockers -----
    match /lockers/{lockerId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // ----- Bookings -----
    match /bookings/{bookingId} {
      // Client creates only a RESERVED booking
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.lockerId is string
        && request.resource.data.status == "reserved"
        && request.resource.data.createdAt is timestamp
        && request.resource.data.startAt is timestamp
        && request.resource.data.durationMin is int
        && request.resource.data.durationMin > 0
        && request.resource.data.amount is int
        && request.resource.data.amount == 25;

      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);

      // ✅ Admin can update bookings for Spark demo workflow:
      // reserved -> pending_payment -> active -> completed (or cancelled)
      allow update: if isAdmin()
        || (
          // User cancel only
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status"])
          && request.resource.data.status == "cancelled"
        );

      allow delete: if isAdmin();
    }

    // ----- Payments -----
    match /payments/{paymentId} {
      // Keep strict (backend only)
      // ✅ Optionally allow admin create for Spark demo
      allow create: if isAdmin();

      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    // ----- Logs -----
    match /logs/{logId} {
      // ✅ Allow admin to create logs for demo (admin console simulation)
      allow create: if isAdmin();

      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    // ----- Device Commands -----
    match /deviceCommands/{cmdId} {
      allow read, write: if isAdmin();
    }
  }
}